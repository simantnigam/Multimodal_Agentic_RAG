# =============================================================================
# Multimodal Agentic RAG — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Usage:
#   copy .env.example .env
# =============================================================================


# =============================================================================
# APP
# =============================================================================
APP_ENV=development                         # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4                               # Uvicorn workers — set to CPU cores * 2 in prod
LOG_LEVEL=INFO                              # DEBUG | INFO | WARNING | ERROR


# =============================================================================
# DATABASE  (Phase 1)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://admin:admin@localhost:5432/rag_db

# Connection pool (Phase 8 — production tuning)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10


# =============================================================================
# REDIS  (Phase 6 — query cache)
# =============================================================================
# Note: install with:  uv add redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600                      # Query cache TTL in seconds (1 hour default)


# =============================================================================
# CELERY  (Phase 8 — async ingestion workers)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Queue names (keep separate to allow different worker pools)
CELERY_QUEUE_INGESTION=ingestion
CELERY_QUEUE_EMBEDDING=embedding
CELERY_QUEUE_STORAGE=storage

# Retry config
CELERY_MAX_RETRIES=3
CELERY_RETRY_DELAY=60                       # Seconds between retries


# =============================================================================
# LLM  (Phase 4 — agents)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6                 # Model used by all agents (answer, validator, etc.)
LLM_MAX_TOKENS=1000                         # Max output tokens for answer agent
LLM_TEMPERATURE=0                           # 0 = deterministic; increase for more creative answers

# Optional — only needed if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...


# =============================================================================
# EMBEDDINGS  (Phase 2 — ingestion + Phase 3 — retrieval)
# =============================================================================
EMBEDDING_PROVIDER=bge                      # bge | openai
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5     # Must match at both ingestion and query time
EMBEDDING_MODEL_VERSION=bge-large-en-v1.5  # Stored per chunk in DB for consistency checks
EMBEDDING_DIM=1024                          # bge-large=1024 | bge-base=768 | text-embedding-3-large=3072
EMBEDDING_BATCH_SIZE=64                     # Chunks per embedding batch (32–128)

# Known model → dim reference:
#   BAAI/bge-large-en-v1.5    → 1024  (default)
#   BAAI/bge-base-en-v1.5     → 768
#   text-embedding-3-small     → 1536
#   text-embedding-3-large     → 3072


# =============================================================================
# CHUNKING  (Phase 2 — ingestion)
# =============================================================================
CHUNKING_SIMILARITY_THRESHOLD=0.75         # Cosine similarity below which a new chunk is created
CHUNK_MIN_TOKENS=150                        # Merge chunk below this size with adjacent
CHUNK_MAX_TOKENS=600                        # Split chunk above this size semantically


# =============================================================================
# RETRIEVAL  (Phase 3)
# =============================================================================
TOP_K_PRE_RERANK=20                         # Candidates fetched before reranking
TOP_K_POST_RERANK=5                         # Final chunks passed to context assembly
DENSE_WEIGHT=0.7                            # α in: final_score = α*dense_norm + β*bm25_norm
SPARSE_WEIGHT=0.3                           # β — must sum to 1.0 with DENSE_WEIGHT

# IVFFlat index tuning (Phase 8 — production)
IVFFLAT_PROBES=10                           # Higher = better recall, slower query (default: lists/10)


# =============================================================================
# AGENTS & ORCHESTRATION  (Phase 4 + Phase 5)
# =============================================================================
VALIDATOR_THRESHOLD=0.75                    # Minimum final_score to PASS validation
MAX_RETRIES=2                               # Max re-retrieval attempts before degrading

# Context assembly (Phase 4)
CONTEXT_MAX_TOKENS=4000                     # Token budget for assembled context window passed to LLM

# Query expansion (Phase 4)
QUERY_EXPANSION_COUNT=3                     # Number of alternative queries to generate (3–5)


# =============================================================================
# OBSERVABILITY  (Phase 7 + Phase 8)
# =============================================================================
# LangSmith — tracing
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=multimodal-rag
LANGSMITH_TRACING=true                      # Set to false to disable tracing in dev

# Prometheus
PROMETHEUS_PORT=9090                        # Port for /metrics endpoint


# =============================================================================
# EVALUATION  (Phase 7)
# =============================================================================
EVAL_GOLDEN_DATASET_PATH=data/golden_dataset.json
EVAL_PRECISION_K=5                          # K for Precision@K and Recall@K
EVAL_LLM_JUDGE_MODEL=claude-sonnet-4-6     # Model used for LLM-as-judge scoring

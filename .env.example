# =============================================================================
# Multimodal Agentic RAG — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Usage:
#   copy .env.example .env
# =============================================================================


# =============================================================================
# APP
# =============================================================================
# development | staging | production
APP_ENV=development
APP_HOST=0.0.0.0
# Uvicorn workers — set to CPU cores * 2 in prod
APP_WORKERS=4
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO


# =============================================================================
# DATABASE  (Phase 1)
# =============================================================================
DATABASE_URL=postgresql+asyncpg://admin:admin@localhost:5432/rag_db

# Connection pool (Phase 8 — production tuning)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10


# =============================================================================
# REDIS  (Phase 6 — query cache)
# =============================================================================
# Note: install with:  uv add redis
REDIS_URL=redis://localhost:6379/0
# Query cache TTL in seconds
CACHE_TTL_SECONDS=3600


# =============================================================================
# CELERY  (Phase 8 — async ingestion workers)
# =============================================================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Queue names — keep separate to allow different worker pools
CELERY_QUEUE_INGESTION=ingestion
CELERY_QUEUE_EMBEDDING=embedding
CELERY_QUEUE_STORAGE=storage

# Retry config
CELERY_MAX_RETRIES=3
# Seconds between retries
CELERY_RETRY_DELAY=60


# =============================================================================
# LLM  (Phase 4 — agents)
# =============================================================================
ANTHROPIC_API_KEY=sk-ant-...
# Model used by all agents (answer, validator, etc.)
LLM_MODEL=claude-sonnet-4-6
# Max output tokens for answer agent
LLM_MAX_TOKENS=1000
# 0 = deterministic; increase for more creative answers
LLM_TEMPERATURE=0

# Optional — only needed if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...

# =============================================================================
# VISION  (image captioning during ingestion)
# =============================================================================
# anthropic | openai | none
# Auto-detected from API keys if not set (anthropic preferred)
VISION_PROVIDER=anthropic
# Claude model used for image captioning (must support vision)
VISION_MODEL=claude-sonnet-4-6
# Max tokens for caption response
VISION_MAX_TOKENS=300


# =============================================================================
# EMBEDDINGS  (Phase 2 — ingestion + Phase 3 — retrieval)
# =============================================================================
HF_HUB_DISABLE_SYMLINKS_WARNING=1

# bge | openai
EMBEDDING_PROVIDER=bge
# Must match at both ingestion and query time
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
# Stored per chunk in DB for consistency checks
EMBEDDING_MODEL_VERSION=bge-large-en-v1.5
# bge-large=1024 | bge-base=768 | text-embedding-3-large=3072
EMBEDDING_DIM=1024
# Chunks per embedding batch (32-128)
EMBEDDING_BATCH_SIZE=64

# Known model -> dim reference:
#   BAAI/bge-large-en-v1.5  -> 1024  (default)
#   BAAI/bge-base-en-v1.5   -> 768
#   text-embedding-3-small   -> 1536
#   text-embedding-3-large   -> 3072


# =============================================================================
# CHUNKING  (Phase 2 — ingestion)
# =============================================================================
# Cosine similarity below which a new chunk is created
CHUNKING_SIMILARITY_THRESHOLD=0.75
# Merge chunk below this size with adjacent
CHUNK_MIN_TOKENS=150
# Split chunk above this size semantically
CHUNK_MAX_TOKENS=600


# =============================================================================
# RETRIEVAL  (Phase 3)
# =============================================================================
# Candidates fetched before reranking
TOP_K_PRE_RERANK=20
# Final chunks passed to context assembly
TOP_K_POST_RERANK=5
# alpha in: final_score = alpha*dense_norm + beta*bm25_norm
DENSE_WEIGHT=0.7
# beta — must sum to 1.0 with DENSE_WEIGHT
SPARSE_WEIGHT=0.3

# IVFFlat index tuning (Phase 8 — production)
# Higher = better recall, slower query (default: lists/10)
IVFFLAT_PROBES=10


# =============================================================================
# AGENTS & ORCHESTRATION  (Phase 4 + Phase 5)
# =============================================================================
# Minimum final_score to PASS validation
VALIDATOR_THRESHOLD=0.75
# Max re-retrieval attempts before degrading
MAX_RETRIES=2

# Context assembly (Phase 4)
# Token budget for assembled context window passed to LLM
CONTEXT_MAX_TOKENS=4000

# Query expansion (Phase 4)
# Number of alternative queries to generate (3-5)
QUERY_EXPANSION_COUNT=3


# =============================================================================
# OBSERVABILITY  (Phase 7 + Phase 8)
# =============================================================================
# LangSmith — tracing
LANGSMITH_API_KEY=ls__...
LANGSMITH_PROJECT=multimodal-rag
# Set to false to disable tracing in dev
LANGSMITH_TRACING=false

# Prometheus
# Port for /metrics endpoint
PROMETHEUS_PORT=9090


# =============================================================================
# EVALUATION  (Phase 7)
# =============================================================================
EVAL_GOLDEN_DATASET_PATH=data/golden_dataset.json
# K for Precision@K and Recall@K
EVAL_PRECISION_K=5
# Model used for LLM-as-judge scoring
EVAL_LLM_JUDGE_MODEL=claude-sonnet-4-6
